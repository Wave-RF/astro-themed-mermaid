{
  "name": "@wave-rf/astro-themed-mermaid",
  "version": "0.3.0",
  "description": "Build-time, theme-aware Mermaid diagrams for Astro / Starlight — color-agnostic SVG rewriting (CSS-variable theming, cluster-title pills, edge-label pills) on top of rehype-mermaid.",
  "type": "module",
  "license": "MIT",
  "author": "Wave RF",
  "homepage": "https://github.com/Wave-RF/astro-themed-mermaid#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wave-RF/astro-themed-mermaid.git"
  },
  "bugs": {
    "url": "https://github.com/Wave-RF/astro-themed-mermaid/issues"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "starlight",
    "mermaid",
    "rehype-mermaid",
    "diagrams",
    "theming",
    "dark-mode"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.mjs"
    },
    "./styles.css": "./styles.css"
  },
  "main": "./index.mjs",
  "types": "./index.d.ts",
  "files": [
    "index.mjs",
    "index.d.ts",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "verify": "biome check . && node --test && bash scripts/ci-marker.sh write",
    "setup": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "astro": ">=5.0.0",
    "rehype-mermaid": ">=3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  }
}
